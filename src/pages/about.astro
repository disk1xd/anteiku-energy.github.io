---
import BaseLayout from "../layouts/BaseLayout.astro";
import { members } from "../data/members";
---

<BaseLayout title="About · Anteiku">
  <section class="wrap hero">
    <p class="kicker">about</p>
    <h1>Anteiku</h1>
  </section>

  <section class="wrap prose">
    <p>
      <strong>Anteiku</strong> is a group of friends who decided to start
      writing down what we work on. Among us there are red team operators,
      pentesters, computer science students, and a few others.
    </p>
    <p>
      It isn't a journal or a corporate blog. Not everyone here writes, and
      that's fine.
    </p>
  </section>

  <section class="wrap members-section">
    <h2 class="year-label">members</h2>
    <ul class="members">
      {
        members.map((m) => (
          <li>
            <div class="member">
              <span class="nick">{m.nick}</span>
              {m.bio ? (
                <p class="bio">{m.bio}</p>
              ) : (
                <p class="bio bio--empty">…</p>
              )}
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
